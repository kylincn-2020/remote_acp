{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM"],
    "types": ["node"],
    "strict": true,
    "declaration": true,
    "sourceMap": true,
    "outDir": "../dist/connector",
    "rootDir": ".",
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts", "examples/**/*.ts"]
}
